theory sel_add_zero
    imports  arith_lemmas bitwise_lemmas
begin
theorem sel_add_zero_th:
"(bw w (sel (bw 1 s) (bw w ((bw w a) + (bw w b))) (bw w ((bw w c) + (bw w d)))))=(bw w ((bw w (sel (bw 1 s) (bw w a) (bw w c))) + (bw w (sel (bw 1 s) (bw w b) (bw w d)))))" (is "?lhs = ?rhs")
if "(1 > 0)" and "(w > 0)"
for w :: nat and a c b d s :: int
proof -
    have "?lhs = (bw w (((bw w ((bw w a) + (bw w b))) * (bw 1 (bw 1 s))) + ((bw w ((bw w c) + (bw w d))) * (bw 1 (not (bw 1 (bw 1 s)))))))" by (simp add: sel_def)
    moreover have "... = (bw w (((bw w ((bw w c) + (bw w d))) * (bw 1 (not (bw 1 (bw 1 s))))) + ((bw w ((bw w a) + (bw w b))) * (bw 1 (bw 1 s)))))" using add.commute that by (simp ; fail | simp only: add.commute; fail | simp add: add.commute; fail | blast; fail | metis)
