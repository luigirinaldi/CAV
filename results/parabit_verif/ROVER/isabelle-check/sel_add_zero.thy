    moreover have "... = (bw w (((bw 1 (not (bw 1 (bw 1 s)))) * ((bw w c) + (bw w d))) + ((b + (bw w a)) * (bw 1 (bw 1 s)))))" using mult.commute that by (simp ; fail | simp only: mult.commute; fail | simp add: mult.commute; fail | blast; fail | metis)
    moreover have "... = (bw w ((((bw 1 (not (bw 1 (bw 1 s)))) * (bw w c)) + ((bw 1 (not (bw 1 (bw 1 s)))) * (bw w d))) + ((b + (bw w a)) * (bw 1 (bw 1 s)))))" using int_distrib that by (simp ; fail | simp only: int_distrib; fail | simp add: int_distrib; fail | blast; fail | metis)
    moreover have "... = (bw w ((((bw w c) * (bw 1 (not (bw 1 (bw 1 s))))) + ((bw 1 (not (bw 1 (bw 1 s)))) * (bw w d))) + ((b + (bw w a)) * (bw 1 (bw 1 s)))))" using mult.commute that by (simp ; fail | simp only: mult.commute; fail | simp add: mult.commute; fail | blast; fail | metis)
    moreover have "... = (bw w ((((bw w c) * (bw 1 (not (bw 1 (bw 1 s))))) + ((bw w d) * (bw 1 (not (bw 1 (bw 1 s)))))) + ((b + (bw w a)) * (bw 1 (bw 1 s)))))" using mult.commute that by (simp ; fail | simp only: mult.commute; fail | simp add: mult.commute; fail | blast; fail | metis)
    moreover have "... = (bw w (((bw w c) * (bw 1 (not (bw 1 (bw 1 s))))) + (((bw w d) * (bw 1 (not (bw 1 (bw 1 s))))) + ((b + (bw w a)) * (bw 1 (bw 1 s))))))" using add.assoc that by (simp ; fail | simp only: add.assoc; fail | simp add: add.assoc; fail | blast; fail | metis)
    moreover have "... = (bw w (((bw w c) * (bw 1 (not (bw 1 (bw 1 s))))) + (((bw w d) * (bw 1 (not (bw 1 (bw 1 s))))) + ((bw 1 (bw 1 s)) * (b + (bw w a))))))" using mult.commute that by (simp ; fail | simp only: mult.commute; fail | simp add: mult.commute; fail | blast; fail | metis)
    moreover have "... = (bw w (((bw w c) * (bw 1 (not (bw 1 (bw 1 s))))) + (((bw w d) * (bw 1 (not (bw 1 (bw 1 s))))) + (((bw 1 (bw 1 s)) * b) + ((bw 1 (bw 1 s)) * (bw w a))))))" using int_distrib that by (simp ; fail | simp only: int_distrib; fail | simp add: int_distrib; fail | blast; fail | metis)
    moreover have "... = (bw w (((bw w c) * (bw 1 (not (bw 1 (bw 1 s))))) + (((bw w d) * (bw 1 (not (bw 1 (bw 1 s))))) + ((b * (bw 1 (bw 1 s))) + ((bw 1 (bw 1 s)) * (bw w a))))))" using mult.commute that by (simp ; fail | simp only: mult.commute; fail | simp add: mult.commute; fail | blast; fail | metis)
    moreover have "... = (bw w (((bw w c) * (bw 1 (not (bw 1 (bw 1 s))))) + (((bw w d) * (bw 1 (not (bw 1 (bw 1 s))))) + ((b * (bw 1 (bw 1 s))) + ((bw w a) * (bw 1 (bw 1 s)))))))" using mult.commute that by (simp ; fail | simp only: mult.commute; fail | simp add: mult.commute; fail | blast; fail | metis)
    moreover have "... = (bw w (((bw w c) * (bw 1 (not (bw 1 (bw 1 s))))) + ((((bw w d) * (bw 1 (not (bw 1 (bw 1 s))))) + (b * (bw 1 (bw 1 s)))) + ((bw w a) * (bw 1 (bw 1 s))))))" using add.assoc that by (simp ; fail | simp only: add.assoc; fail | simp add: add.assoc; fail | blast; fail | metis)
    moreover have "... = (bw w (((bw w c) * (bw 1 (not (bw 1 (bw 1 s))))) + (((b * (bw 1 (bw 1 s))) + ((bw w d) * (bw 1 (not (bw 1 (bw 1 s)))))) + ((bw w a) * (bw 1 (bw 1 s))))))" using add.commute that by (simp ; fail | simp only: add.commute; fail | simp add: add.commute; fail | blast; fail | metis)
    moreover have "... = (bw w (((bw w c) * (bw 1 (not (bw 1 (bw 1 s))))) + (((bw w a) * (bw 1 (bw 1 s))) + ((b * (bw 1 (bw 1 s))) + ((bw w d) * (bw 1 (not (bw 1 (bw 1 s)))))))))" using add.commute that by (simp ; fail | simp only: add.commute; fail | simp add: add.commute; fail | blast; fail | metis)
    moreover have "... = (bw w ((((bw w c) * (bw 1 (not (bw 1 (bw 1 s))))) + ((bw w a) * (bw 1 (bw 1 s)))) + ((b * (bw 1 (bw 1 s))) + ((bw w d) * (bw 1 (not (bw 1 (bw 1 s))))))))" using add.assoc that by (simp ; fail | simp only: add.assoc; fail | simp add: add.assoc; fail | blast; fail | metis)
    moreover have "... = (bw w ((((bw w a) * (bw 1 (bw 1 s))) + ((bw w c) * (bw 1 (not (bw 1 (bw 1 s)))))) + ((b * (bw 1 (bw 1 s))) + ((bw w d) * (bw 1 (not (bw 1 (bw 1 s))))))))" using add.commute that by (simp ; fail | simp only: add.commute; fail | simp add: add.commute; fail | blast; fail | metis)
    moreover have "... = (bw w ((bw w (((bw w a) * (bw 1 (bw 1 s))) + ((bw w c) * (bw 1 (not (bw 1 (bw 1 s))))))) + ((b * (bw 1 (bw 1 s))) + ((bw w d) * (bw 1 (not (bw 1 (bw 1 s))))))))" using add_eq_prec that by (simp ; fail | simp only: add_eq_prec; fail | simp add: add_eq_prec; fail | blast; fail | metis)
    moreover have "... = (bw w ((bw w (sel (bw 1 s) (bw w a) (bw w c))) + ((b * (bw 1 (bw 1 s))) + ((bw w d) * (bw 1 (not (bw 1 (bw 1 s))))))))" by (simp add: sel_def)
    moreover have "... = (bw w ((bw w (not (bw w (not (bw w (sel (bw 1 s) (bw w a) (bw w c))))))) + ((b * (bw 1 (bw 1 s))) + ((bw w d) * (bw 1 (not (bw 1 (bw 1 s))))))))" using not_bw_not that by (simp ; fail | simp only: not_bw_not; fail | simp add: not_bw_not; fail | blast; fail | metis)
    moreover have "... = (bw w ((not (bw w (not (bw w (sel (bw 1 s) (bw w a) (bw w c)))))) + ((b * (bw 1 (bw 1 s))) + ((bw w d) * (bw 1 (not (bw 1 (bw 1 s))))))))" using add_eq_prec that by (simp ; fail | simp only: add_eq_prec; fail | simp add: add_eq_prec; fail | blast; fail | metis)
    moreover have "... = (bw w (((b * (bw 1 (bw 1 s))) + ((bw w d) * (bw 1 (not (bw 1 (bw 1 s)))))) + (not (bw w (not (bw w (sel (bw 1 s) (bw w a) (bw w c))))))))" using add.commute that by (simp ; fail | simp only: add.commute; fail | simp add: add.commute; fail | blast; fail | metis)
    moreover have "... = (bw w ((bw w ((b * (bw 1 (bw 1 s))) + ((bw w d) * (bw 1 (not (bw 1 (bw 1 s))))))) + (not (bw w (not (bw w (sel (bw 1 s) (bw w a) (bw w c))))))))" using add_eq_prec that by (simp ; fail | simp only: add_eq_prec; fail | simp add: add_eq_prec; fail | blast; fail | metis)
    moreover have "... = (bw w ((bw w ((bw w (b * (bw 1 (bw 1 s)))) + ((bw w d) * (bw 1 (not (bw 1 (bw 1 s))))))) + (not (bw w (not (bw w (sel (bw 1 s) (bw w a) (bw w c))))))))" using add_eq_prec that by (simp ; fail | simp only: add_eq_prec; fail | simp add: add_eq_prec; fail | blast; fail | metis)
    moreover have "... = (bw w ((bw w ((bw w ((bw w b) * (bw 1 (bw 1 s)))) + ((bw w d) * (bw 1 (not (bw 1 (bw 1 s))))))) + (not (bw w (not (bw w (sel (bw 1 s) (bw w a) (bw w c))))))))" using mul_eq_prec that by (simp ; fail | simp only: mul_eq_prec; fail | simp add: mul_eq_prec; fail | blast; fail | metis)
    moreover have "... = (bw w ((bw w (((bw w b) * (bw 1 (bw 1 s))) + ((bw w d) * (bw 1 (not (bw 1 (bw 1 s))))))) + (not (bw w (not (bw w (sel (bw 1 s) (bw w a) (bw w c))))))))" using that bw_def mod_prop_sum by (presburger ; fail | blast)
    moreover have "... = (bw w ((bw w (sel (bw 1 s) (bw w b) (bw w d))) + (not (bw w (not (bw w (sel (bw 1 s) (bw w a) (bw w c))))))))" by (simp add: sel_def)
    moreover have "... = (bw w ((not (bw w (not (bw w (sel (bw 1 s) (bw w a) (bw w c)))))) + (bw w (sel (bw 1 s) (bw w b) (bw w d)))))" using add.commute that by (simp ; fail | simp only: add.commute; fail | simp add: add.commute; fail | blast; fail | metis)
    moreover have "... = (bw w ((bw w (not (bw w (not (bw w (sel (bw 1 s) (bw w a) (bw w c))))))) + (bw w (sel (bw 1 s) (bw w b) (bw w d)))))" using add_eq_prec that by (simp ; fail | simp only: add_eq_prec; fail | simp add: add_eq_prec; fail | blast; fail | metis)
    moreover have "... = (bw w ((bw w (sel (bw 1 s) (bw w a) (bw w c))) + (bw w (sel (bw 1 s) (bw w b) (bw w d)))))" using not_bw_not that by (simp ; fail | simp only: not_bw_not; fail | simp add: not_bw_not; fail | blast; fail | metis)
ultimately show ?thesis by argo
qed

end
