    moreover have "... = (bw w ((bw w (((bw w c) + (bw w d)) * (bw 1 (not (bw 1 (bw 1 s)))))) + ((bw w ((bw w a) + (bw w b))) * (bw 1 (bw 1 s)))))" using mul_eq_prec that by (simp ; fail | simp only: mul_eq_prec; fail | simp add: mul_eq_prec; fail | blast; fail | metis)
    moreover have "... = (bw w ((((bw w c) + (bw w d)) * (bw 1 (not (bw 1 (bw 1 s))))) + ((bw w ((bw w a) + (bw w b))) * (bw 1 (bw 1 s)))))" using add_eq_prec that by (simp ; fail | simp only: add_eq_prec; fail | simp add: add_eq_prec; fail | blast; fail | metis)
    moreover have "... = (bw w (((bw w ((bw w a) + (bw w b))) * (bw 1 (bw 1 s))) + (((bw w c) + (bw w d)) * (bw 1 (not (bw 1 (bw 1 s)))))))" using add.commute that by (simp ; fail | simp only: add.commute; fail | simp add: add.commute; fail | blast; fail | metis)
    moreover have "... = (bw w (((bw w ((bw w a) + (bw w b))) * (bw 1 s)) + (((bw w c) + (bw w d)) * (bw 1 (not (bw 1 (bw 1 s)))))))" using mod_eq that by (simp ; fail | simp only: mod_eq; fail | simp add: mod_eq; fail | blast; fail | metis)
    moreover have "... = (bw w ((bw w ((bw w ((bw w a) + (bw w b))) * (bw 1 s))) + (((bw w c) + (bw w d)) * (bw 1 (not (bw 1 (bw 1 s)))))))" using mul_by_bit_eq that by (simp ; fail | simp only: mul_by_bit_eq; fail | simp add: mul_by_bit_eq; fail | blast; fail | metis)
    moreover have "... = (bw w ((bw w ((bw w ((bw w a) + (bw w b))) * (bw 1 (bw 1 s)))) + (((bw w c) + (bw w d)) * (bw 1 (not (bw 1 (bw 1 s)))))))" using mod_eq that by (simp ; fail | simp only: mod_eq; fail | simp add: mod_eq; fail | blast; fail | metis)
    moreover have "... = (bw w ((bw w ((bw w ((bw w b) + (bw w a))) * (bw 1 (bw 1 s)))) + (((bw w c) + (bw w d)) * (bw 1 (not (bw 1 (bw 1 s)))))))" using add.commute that by (simp ; fail | simp only: add.commute; fail | simp add: add.commute; fail | blast; fail | metis)
    moreover have "... = (bw w ((bw w ((bw w (b + (bw w a))) * (bw 1 (bw 1 s)))) + (((bw w c) + (bw w d)) * (bw 1 (not (bw 1 (bw 1 s)))))))" using add_eq_prec that by (simp ; fail | simp only: add_eq_prec; fail | simp add: add_eq_prec; fail | blast; fail | metis)
    moreover have "... = (bw w ((bw w ((b + (bw w a)) * (bw 1 (bw 1 s)))) + (((bw w c) + (bw w d)) * (bw 1 (not (bw 1 (bw 1 s)))))))" using mul_eq_prec that by (simp ; fail | simp only: mul_eq_prec; fail | simp add: mul_eq_prec; fail | blast; fail | metis)
    moreover have "... = (bw w (((b + (bw w a)) * (bw 1 (bw 1 s))) + (((bw w c) + (bw w d)) * (bw 1 (not (bw 1 (bw 1 s)))))))" using add_eq_prec that by (simp ; fail | simp only: add_eq_prec; fail | simp add: add_eq_prec; fail | blast; fail | metis)
