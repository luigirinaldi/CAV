    moreover have "... = (bw w (((not (bw w (not (bw w b)))) * (bw 1 (not (bw 1 (bw 1 s))))) + (((-1) * ((bw w a) * (bw 1 (not (bw 1 (bw 1 s)))))) + (((-1) * ((bw w b) * (bw 1 (bw 1 s)))) + ((bw 1 (bw 1 s)) * (bw w a))))))" using mult.assoc that by (simp ; fail | simp only: mult.assoc; fail | simp add: mult.assoc; fail | blast; fail | metis)
    moreover have "... = (bw w (((not (bw w (not (bw w b)))) * (bw 1 (not (bw 1 (bw 1 s))))) + (((-1) * ((bw w a) * (bw 1 (not (bw 1 (bw 1 s)))))) + (((-1) * ((bw w b) * (bw 1 (bw 1 s)))) + ((bw w a) * (bw 1 (bw 1 s)))))))" using mult.commute that by (simp ; fail | simp only: mult.commute; fail | simp add: mult.commute; fail | blast; fail | metis)
    moreover have "... = (bw w (((not (bw w (not (bw w b)))) * (bw 1 (not (bw 1 (bw 1 s))))) + ((((-1) * ((bw w a) * (bw 1 (not (bw 1 (bw 1 s)))))) + ((-1) * ((bw w b) * (bw 1 (bw 1 s))))) + ((bw w a) * (bw 1 (bw 1 s))))))" using add.assoc that by (simp ; fail | simp only: add.assoc; fail | simp add: add.assoc; fail | blast; fail | metis)
    moreover have "... = (bw w (((not (bw w (not (bw w b)))) * (bw 1 (not (bw 1 (bw 1 s))))) + (((-1) * (((bw w a) * (bw 1 (not (bw 1 (bw 1 s))))) + ((bw w b) * (bw 1 (bw 1 s))))) + ((bw w a) * (bw 1 (bw 1 s))))))" using int_distrib that by (simp ; fail | simp only: int_distrib; fail | simp add: int_distrib; fail | blast; fail | metis)
    moreover have "... = (bw w (((not (bw w (not (bw w b)))) * (bw 1 (not (bw 1 (bw 1 s))))) + (((-1) * (((bw w b) * (bw 1 (bw 1 s))) + ((bw w a) * (bw 1 (not (bw 1 (bw 1 s))))))) + ((bw w a) * (bw 1 (bw 1 s))))))" using add.commute that by (simp ; fail | simp only: add.commute; fail | simp add: add.commute; fail | blast; fail | metis)
