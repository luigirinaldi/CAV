theory equation_abc
    imports  signed_lemmas arith_lemmas
begin
theorem equation_abc_th:
"(bw w7 ((bw w7 ((bw w7 (signed w8 (bw w8 ((bw w4 ct) - (bw w1 a))))) * (bw w7 (signed w3 (bw w3 c))))) + (bw w7 ((bw w1 a) * (bw w7 d)))))=(bw w7 ((bw w7 ((bw w7 (signed w3 (bw w3 c))) * (bw w7 (signed w9 (bw w9 (bw w4 ct)))))) + (bw w7 ((bw w1 a) * (bw w7 ((bw w7 (signed w7 (bw w7 d))) - (bw w7 (signed w3 (bw w3 c)))))))))" (is "?lhs = ?rhs")
if "(w8 > w1)" and "(w8 > w4)" and "(w9 > w4)" and "(w9 > 0)" and "(w8 > 0)" and "(w3 > 0)" and "(w4 > 0)" and "(w7 > 0)" and "(w1 > 0)"
for w7 w4 w3 w9 w1 w8 :: nat and a c d ct :: int
proof -
    have "?lhs = (bw w7 ((bw w7 ((bw w1 a) * (bw w7 d))) + (bw w7 ((bw w7 (signed w8 (bw w8 ((bw w4 ct) - (bw w1 a))))) * (bw w7 (signed w3 (bw w3 c)))))))" using add.commute that by (simp ; fail | simp only: add.commute; fail | simp add: add.commute; fail | blast; fail | metis)
    moreover have "... = (bw w7 (((bw w1 a) * (bw w7 d)) + (bw w7 ((bw w7 (signed w8 (bw w8 ((bw w4 ct) - (bw w1 a))))) * (bw w7 (signed w3 (bw w3 c)))))))" using add_eq_prec that by (simp ; fail | simp only: add_eq_prec; fail | simp add: add_eq_prec; fail | blast; fail | metis)
    moreover have "... = (bw w7 ((bw w7 ((bw w7 (signed w8 (bw w8 ((bw w4 ct) - (bw w1 a))))) * (bw w7 (signed w3 (bw w3 c))))) + ((bw w1 a) * (bw w7 d))))" using add.commute that by (simp ; fail | simp only: add.commute; fail | simp add: add.commute; fail | blast; fail | metis)
    moreover have "... = (bw w7 ((bw w7 ((bw w7 ((bw w4 ct) - (bw w1 a))) * (bw w7 (signed w3 (bw w3 c))))) + ((bw w1 a) * (bw w7 d))))" using signed_of_diff that by (simp ; fail | simp only: signed_of_diff; fail | simp add: signed_of_diff; fail | blast; fail | metis)
    moreover have "... = (bw w7 ((bw w7 ((bw w7 ((bw w7 (bw w4 ct)) - (bw w1 a))) * (bw w7 (signed w3 (bw w3 c))))) + ((bw w1 a) * (bw w7 d))))" using that mod_prop_sub_left by (blast; fail | metis)
    moreover have "... = (bw w7 ((bw w7 ((bw w7 ((bw w7 (signed w9 (bw w9 (bw w4 ct)))) - (bw w1 a))) * (bw w7 (signed w3 (bw w3 c))))) + ((bw w1 a) * (bw w7 d))))" using signed_zext that by (simp ; fail | simp only: signed_zext; fail | simp add: signed_zext; fail | blast; fail | metis)
    moreover have "... = (bw w7 ((bw w7 (((bw w7 (signed w9 (bw w9 (bw w4 ct)))) - (bw w1 a)) * (bw w7 (signed w3 (bw w3 c))))) + ((bw w1 a) * (bw w7 d))))" using mul_eq_prec that by (simp ; fail | simp only: mul_eq_prec; fail | simp add: mul_eq_prec; fail | blast; fail | metis)
    moreover have "... = (bw w7 ((((bw w7 (signed w9 (bw w9 (bw w4 ct)))) - (bw w1 a)) * (bw w7 (signed w3 (bw w3 c)))) + ((bw w1 a) * (bw w7 d))))" using add_eq_prec that by (simp ; fail | simp only: add_eq_prec; fail | simp add: add_eq_prec; fail | blast; fail | metis)
    moreover have "... = (bw w7 (((bw w1 a) * (bw w7 d)) + (((bw w7 (signed w9 (bw w9 (bw w4 ct)))) - (bw w1 a)) * (bw w7 (signed w3 (bw w3 c))))))" using add.commute that by (simp ; fail | simp only: add.commute; fail | simp add: add.commute; fail | blast; fail | metis)
    moreover have "... = (bw w7 (((bw w1 a) * (bw w7 d)) + ((bw w7 (signed w3 (bw w3 c))) * ((bw w7 (signed w9 (bw w9 (bw w4 ct)))) - (bw w1 a)))))" using mult.commute that by (simp ; fail | simp only: mult.commute; fail | simp add: mult.commute; fail | blast; fail | metis)
    moreover have "... = (bw w7 (((bw w1 a) * (bw w7 d)) + ((bw w7 (signed w3 (bw w3 c))) * ((bw w7 (signed w9 (bw w9 (bw w4 ct)))) + ((-1) * (bw w1 a))))))" using sub_to_neg that by (simp ; fail | simp only: sub_to_neg; fail | simp add: sub_to_neg; fail | blast; fail | metis)
    moreover have "... = (bw w7 (((bw w1 a) * (bw w7 d)) + ((bw w7 (signed w3 (bw w3 c))) * (((-1) * (bw w1 a)) + (bw w7 (signed w9 (bw w9 (bw w4 ct))))))))" using add.commute that by (simp ; fail | simp only: add.commute; fail | simp add: add.commute; fail | blast; fail | metis)
    moreover have "... = (bw w7 (((bw w1 a) * (bw w7 d)) + (((bw w7 (signed w3 (bw w3 c))) * ((-1) * (bw w1 a))) + ((bw w7 (signed w3 (bw w3 c))) * (bw w7 (signed w9 (bw w9 (bw w4 ct))))))))" using int_distrib that by (simp ; fail | simp only: int_distrib; fail | simp add: int_distrib; fail | blast; fail | metis)
    moreover have "... = (bw w7 (((bw w1 a) * (bw w7 d)) + ((((-1) * (bw w1 a)) * (bw w7 (signed w3 (bw w3 c)))) + ((bw w7 (signed w3 (bw w3 c))) * (bw w7 (signed w9 (bw w9 (bw w4 ct))))))))" using mult.commute that by (simp ; fail | simp only: mult.commute; fail | simp add: mult.commute; fail | blast; fail | metis)
    moreover have "... = (bw w7 (((bw w1 a) * (bw w7 d)) + ((((bw w1 a) * (-1)) * (bw w7 (signed w3 (bw w3 c)))) + ((bw w7 (signed w3 (bw w3 c))) * (bw w7 (signed w9 (bw w9 (bw w4 ct))))))))" using mult.commute that by (simp ; fail | simp only: mult.commute; fail | simp add: mult.commute; fail | blast; fail | metis)
    moreover have "... = (bw w7 (((bw w1 a) * (bw w7 d)) + (((bw w1 a) * ((-1) * (bw w7 (signed w3 (bw w3 c))))) + ((bw w7 (signed w3 (bw w3 c))) * (bw w7 (signed w9 (bw w9 (bw w4 ct))))))))" using mult.assoc that by (simp ; fail | simp only: mult.assoc; fail | simp add: mult.assoc; fail | blast; fail | metis)
    moreover have "... = (bw w7 ((((bw w1 a) * (bw w7 d)) + ((bw w1 a) * ((-1) * (bw w7 (signed w3 (bw w3 c)))))) + ((bw w7 (signed w3 (bw w3 c))) * (bw w7 (signed w9 (bw w9 (bw w4 ct)))))))" using add.assoc that by (simp ; fail | simp only: add.assoc; fail | simp add: add.assoc; fail | blast; fail | metis)
    moreover have "... = (bw w7 (((bw w1 a) * ((bw w7 d) + ((-1) * (bw w7 (signed w3 (bw w3 c)))))) + ((bw w7 (signed w3 (bw w3 c))) * (bw w7 (signed w9 (bw w9 (bw w4 ct)))))))" using int_distrib that by (simp ; fail | simp only: int_distrib; fail | simp add: int_distrib; fail | blast; fail | metis)
    moreover have "... = (bw w7 (((bw w1 a) * ((bw w7 d) - (bw w7 (signed w3 (bw w3 c))))) + ((bw w7 (signed w3 (bw w3 c))) * (bw w7 (signed w9 (bw w9 (bw w4 ct)))))))" using sub_to_neg that by (simp ; fail | simp only: sub_to_neg; fail | simp add: sub_to_neg; fail | blast; fail | metis)
    moreover have "... = (bw w7 (((bw w1 a) * ((bw w7 (signed w7 (bw w7 d))) - (bw w7 (signed w3 (bw w3 c))))) + ((bw w7 (signed w3 (bw w3 c))) * (bw w7 (signed w9 (bw w9 (bw w4 ct)))))))" using redundant_signed that by (simp ; fail | simp only: redundant_signed; fail | simp add: redundant_signed; fail | blast; fail | metis)
    moreover have "... = (bw w7 ((((bw w7 (signed w7 (bw w7 d))) - (bw w7 (signed w3 (bw w3 c)))) * (bw w1 a)) + ((bw w7 (signed w3 (bw w3 c))) * (bw w7 (signed w9 (bw w9 (bw w4 ct)))))))" using mult.commute that by (simp ; fail | simp only: mult.commute; fail | simp add: mult.commute; fail | blast; fail | metis)
    moreover have "... = (bw w7 ((bw w7 (((bw w7 (signed w7 (bw w7 d))) - (bw w7 (signed w3 (bw w3 c)))) * (bw w1 a))) + ((bw w7 (signed w3 (bw w3 c))) * (bw w7 (signed w9 (bw w9 (bw w4 ct)))))))" using add_eq_prec that by (simp ; fail | simp only: add_eq_prec; fail | simp add: add_eq_prec; fail | blast; fail | metis)
    moreover have "... = (bw w7 ((bw w7 ((bw w7 ((bw w7 (signed w7 (bw w7 d))) - (bw w7 (signed w3 (bw w3 c))))) * (bw w1 a))) + ((bw w7 (signed w3 (bw w3 c))) * (bw w7 (signed w9 (bw w9 (bw w4 ct)))))))" using mul_eq_prec that by (simp ; fail | simp only: mul_eq_prec; fail | simp add: mul_eq_prec; fail | blast; fail | metis)
    moreover have "... = (bw w7 ((bw w7 ((bw w1 a) * (bw w7 ((bw w7 (signed w7 (bw w7 d))) - (bw w7 (signed w3 (bw w3 c))))))) + ((bw w7 (signed w3 (bw w3 c))) * (bw w7 (signed w9 (bw w9 (bw w4 ct)))))))" using mult.commute that by (simp ; fail | simp only: mult.commute; fail | simp add: mult.commute; fail | blast; fail | metis)
    moreover have "... = (bw w7 (((bw w7 (signed w3 (bw w3 c))) * (bw w7 (signed w9 (bw w9 (bw w4 ct))))) + (bw w7 ((bw w1 a) * (bw w7 ((bw w7 (signed w7 (bw w7 d))) - (bw w7 (signed w3 (bw w3 c)))))))))" using add.commute that by (simp ; fail | simp only: add.commute; fail | simp add: add.commute; fail | blast; fail | metis)
    moreover have "... = (bw w7 ((bw w7 ((bw w7 (signed w3 (bw w3 c))) * (bw w7 (signed w9 (bw w9 (bw w4 ct)))))) + (bw w7 ((bw w1 a) * (bw w7 ((bw w7 (signed w7 (bw w7 d))) - (bw w7 (signed w3 (bw w3 c)))))))))" using add_eq_prec that by (simp ; fail | simp only: add_eq_prec; fail | simp add: add_eq_prec; fail | blast; fail | metis)
ultimately show ?thesis by argo
qed

end
